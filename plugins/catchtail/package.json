{
  "name": "catchtail",
  "version": "0.1.20",
  "type": "module",
  "description": "用于长时间 Codex 会话的本地 hook sidecar，让任务执行中仍可继续交互。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/youngerstyle/CatchTail.git"
  },
  "bin": {
    "catchtail": "./bin/catchtail.js"
  },
  "scripts": {
    "start": "node ./bin/catchtail.js serve"
  },
  "files": [
    ".codex-plugin/",
    "AGENTS.catchtail.md",
    "assets/",
    "README.md",
    "bin/",
    "docs/",
    "hooks/",
    "hooks.json",
    "LICENSE",
    "PRIVACY.md",
    "scripts/",
    "skills/",
    "src/",
    "templates/",
    "TERMS.md"
  ],
  "engines": {
    "node": ">=20"
  }
}
