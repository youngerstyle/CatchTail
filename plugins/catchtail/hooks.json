{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"./hooks/catchtail-hook.js\"",
            "timeout": 600
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"./hooks/catchtail-hook.js\"",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
